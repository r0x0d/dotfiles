#!/usr/bin/bash

if [[ $# -ne 1 ]]; then
    echo "Usage: $0 <archive.tar.gz>"
    exit 1
fi

ARCHIVE="$1"

if [[ ! -f "$ARCHIVE" ]]; then
    echo "Error: File '$ARCHIVE' does not exist."
    exit 1
fi

# Get the top-level directory name from the archive
TOP_DIR=$(tar tf "$ARCHIVE" | head -1 | cut -d/ -f1)

if [[ -z "$TOP_DIR" ]]; then
    echo "Error: Could not determine top-level directory."
    exit 1
fi

# Extract archive
tar xf "$ARCHIVE"

if [[ ! -d "$TOP_DIR" ]]; then
    echo "Error: Expected directory '$TOP_DIR' not found after extraction."
    exit 1
fi

cd "$TOP_DIR"

# Find all regular files and create .orig copies
find . -type f -print0 | while IFS= read -r -d '' file; do
    cp -pav "$file" "$file.orig"
done

echo "Done. All files have been backed up with .orig extension."
