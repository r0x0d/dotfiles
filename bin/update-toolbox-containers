#!/usr/bin/python3

import sys
import subprocess
import time
from dataclasses import dataclass
import argparse


@dataclass
class ToolboxContainer:
    container_id: str
    name: str
    image: str


class bcolors:
    HEADER = "\033[95m"
    OKBLUE = "\033[94m"
    OKCYAN = "\033[96m"
    OKGREEN = "\033[92m"
    WARNING = "\033[93m"
    FAIL = "\033[91m"
    ENDC = "\033[0m"
    BOLD = "\033[1m"
    UNDERLINE = "\033[4m"


def print_status(message: str, color: str) -> None:
    print(f"{color} {message} {bcolors.ENDC}")


def print_inline(message: str, color: str) -> None:
    sys.stdout.write("\r")
    sys.stdout.write(f"{color} {message} {bcolors.ENDC}")
    sys.stdout.flush()


def find_toolbox_containers() -> list[ToolboxContainer]:
    """Find toolbox containers that match a certain criteria

    Criteria is:
        * The toolbox container ends with -dev
        * The name of the container is default
        * The image name starts with quay.io/rr0x0d/toolbox-

    Returns:
        list[ToolboxContainer]: Return a list of `py:ToolboxContainers` matches.
    """
    output = subprocess.run(
        ["podman", "ps", "-a", "--format", "{{ .ID }} - {{ .Names }} - {{ .Image }}"],
        capture_output=True,
    )

    output = [o for o in output.stdout.decode().split("\n") if o]
    matches = []
    for container in output:
        normalized_output = (c.strip() for c in container.split(" - ", 2))
        container_id, name, image = normalized_output
        if (name.endswith("-dev") or name == "default") and image.startswith(
            "quay.io/r0x0d/toolbox-"
        ):
            print_status(f"[+] Found toolbox container: {name}", bcolors.OKBLUE)
            matches.append(
                ToolboxContainer(
                    container_id=container_id.strip(),
                    name=name.strip(),
                    image=image.strip(),
                )
            )

    return matches


def remove_toolbox_container(containers: list[ToolboxContainer]) -> None:
    for container in containers:
        print_status(f"[-] Removing container {container.name}", bcolors.FAIL)
        output = subprocess.run(["podman", "rm", container.container_id, "--force"])
        assert output.returncode == 0, (
            f"Something went wrong while removing container {container.name}"
        )


def update_toolbox_image(containers: list[ToolboxContainer]) -> None:
    for container in containers:
        print_status(f"[+] Updating container image {container.image}", bcolors.OKGREEN)
        output = subprocess.run(["podman", "pull", container.image])
        assert output.returncode == 0, (
            f"Something went wrong while updating container {container.image}"
        )


def recreate_toolbox_container(containers: list[ToolboxContainer]) -> None:
    for container in containers:
        print_status(
            f"[+] Recreating toolbox container {container.name}", bcolors.OKGREEN
        )
        output = subprocess.run(
            ["toolbox", "create", "--image", container.image, container.name]
        )
        assert output.returncode == 0, (
            f"Something went wrong while creating toolbox container {container.name}"
        )


def main() -> int:
    parser = argparse.ArgumentParser(
        prog="update-toolbox-containers",
        description="Update all toolbox images to their latest versions",
    )
    parser.add_argument(
        "-s",
        "--skip",
        help="Skip the warning message for exiting toolbox containers first",
        action="store_true",
    )
    args = parser.parse_args()
    if not args.skip:
        print_status(" ⚠️ WARNING ⚠️", bcolors.WARNING)
        print_status(
            "Please, exit of any toolbox before running the script.", bcolors.WARNING
        )
        print_status(
            "If you are still inside a container, stop this script immediatly!",
            bcolors.WARNING,
        )
        print_status(
            "Save your work before continuing with the update and rerun the script\n\n",
            bcolors.WARNING,
        )
        print_status(
            "You're safe to hit Ctrl + C and stop the script right now.",
            bcolors.WARNING,
        )
        for i in range(10, 0, -1):
            print_inline(f"Seconds remaining: {i:2d}.", bcolors.WARNING)
            sys.stdout.flush()
            time.sleep(1)

        print_status(" ⚠️ WARNING ⚠️", bcolors.WARNING)

    containers = find_toolbox_containers()
    remove_toolbox_container(containers)
    update_toolbox_image(containers)
    recreate_toolbox_container(containers)
    return 0


if __name__ == "__main__":
    sys.exit(main())
